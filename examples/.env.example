# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=crud_api_db
DB_USER=root
DB_PASSWORD=
DB_CHARSET=utf8mb4

# API Configuration
API_VERSION=v1
API_BASE_PATH=/api
API_DEBUG=false

# Authentication
AUTH_METHOD=jwt
# Options: basic|apikey|jwt

# JWT Configuration
JWT_SECRET=change-this-to-a-random-secret-key-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRATION=3600
# JWT expiration in seconds (3600 = 1 hour)
JWT_REFRESH_EXPIRATION=604800
# Refresh token expiration (604800 = 7 days)

# API Key Configuration
API_KEY_PREFIX=ak_live_
API_KEY_LENGTH=32
API_KEY_HASH_ALGO=sha256

# System Tables
API_KEYS_TABLE=api_keys
USERS_TABLE=users

# Bootstrap Configuration
AUTO_SETUP=true
# Automatically create system tables on first run
FIRST_USER_IS_ADMIN=true
# First registered user becomes admin

# Security
ENABLE_CORS=true
ALLOWED_ORIGINS=*
# WARNING: Do NOT use * in production. Use a comma-separated list:
# http://localhost:3000,https://app.example.com
ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
ALLOWED_HEADERS=Content-Type,Authorization,X-API-Key

# Rate Limiting (future feature)
RATE_LIMIT_ENABLED=false
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Password Requirements
MIN_PASSWORD_LENGTH=8
REQUIRE_SPECIAL_CHARS=true
